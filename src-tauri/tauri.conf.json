{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tennis",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
   "build": {
  "beforeDevCommand": {
    "script": "npm run dev",
    "cwd": "../frontend"
  },
  "beforeBuildCommand": {
    "script": "npm run build",
    "cwd": "../frontend"
  },
  "frontendDist": "../frontend/dist",
  "devUrl": "http://localhost:5173"
},
  "app": {
    "windows": [
      {
        "title": "tennis pred",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
